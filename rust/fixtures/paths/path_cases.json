{
  "build_subtitle_path": {
    "basic": {
      "args": {
        "language": "eng",
        "video_path": "movie.mp4"
      },
      "result": "movie.eng.srt"
    },
    "iso1": {
      "args": {
        "language": "eng",
        "naming_type": "iso_639_1",
        "video_path": "movie.mp4"
      },
      "result": "movie.en.srt"
    },
    "name": {
      "args": {
        "language": "eng",
        "naming_type": "name",
        "video_path": "movie.mp4"
      },
      "result": "movie.English.srt"
    },
    "nested_dir": {
      "args": {
        "language": "fra",
        "video_path": "/media/movies/movie.mkv"
      },
      "result": "/media/movies/movie.fre.srt"
    },
    "subgen": {
      "args": {
        "include_subgen_marker": true,
        "language": "eng",
        "video_path": "movie.mp4"
      },
      "result": "movie.subgen.eng.srt"
    },
    "vtt": {
      "args": {
        "extension": ".vtt",
        "language": "spa",
        "video_path": "show.s01e01.mkv"
      },
      "result": "show.s01e01.spa.vtt"
    },
    "with_model": {
      "args": {
        "include_model": true,
        "language": "eng",
        "model_name": "medium",
        "video_path": "movie.mp4"
      },
      "result": "movie.medium.eng.srt"
    }
  },
  "map_path": {
    "disabled": {
      "args": {
        "path": "/host/movie.mkv",
        "path_from": "/host",
        "path_to": "/data",
        "use_mapping": false
      },
      "result": "/host/movie.mkv"
    },
    "enabled": {
      "args": {
        "path": "/host/movie.mkv",
        "path_from": "/host",
        "path_to": "/data",
        "use_mapping": true
      },
      "result": "/data/movie.mkv"
    },
    "no_prefix": {
      "args": {
        "path": "/other/movie.mkv",
        "path_from": "/host",
        "path_to": "/data",
        "use_mapping": true
      },
      "result": "/other/movie.mkv"
    }
  }
}
